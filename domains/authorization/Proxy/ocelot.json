{
    "Routes": [
        {
            "DownstreamPathTemplate": "/wallet-api/v1/{everything}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 5001
                }
            ],
            "UpstreamPathTemplate": "/wallet-api/{everything}",
            "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
            "AddHeadersToRequest": {
                "X-Original-EO_API_VERSION": "EO_API_VERSION"
            },
            "DelegatingHandlers": [
                "VersionHeaderHandler"
            ]
        },
        {
            "DownstreamPathTemplate": "/wallet-api-docs/{everything}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 5001
                }
            ],
            "UpstreamPathTemplate": "/wallet-api-docs/{everything}",
            "UpstreamHttpMethod": [ "GET" ]
        }
    ],
    "GlobalConfiguration": {
        "BaseUrl": "http://localhost:5000"
    }
}
